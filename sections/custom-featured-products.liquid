{% assign s = section.settings %}
{% assign collection = s.featured_collection %}

<section class="custom-products-section">
  <style>
    .custom-products-section {
      max-width: 1200px;
      margin: 40px auto;
      padding: 0 20px;
      font-family: sans-serif;
    }
    .products-heading {
      font-size: 2rem;
      margin-bottom: 25px;
      color: #2d3748;
    }
    .product-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 24px;
    }
    .product-card {
      border: 1px solid #e2e8f0;
      padding: 16px;
      border-radius: 8px;
      background: #fff;
      text-align: center;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .product-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
    }
    .product-card a {
      text-decoration: none;
      color: inherit;
    }
    .product-card img {
      max-width: 100%;
      height: auto;
      border-radius: 6px;
      margin-bottom: 12px;
      object-fit: cover;
    }
    .product-card h3 {
      font-size: 1.1rem;
      margin: 8px 0;
      color: #2d3748;
    }
    .product-card p {
      color: #4a5568;
      font-weight: bold;
      margin: 0;
    }
  </style>

  {% if s.heading != blank %}
    <h2 class="products-heading">{{ s.heading }}</h2>
  {% endif %}

  {% if collection != blank and collection.products.size > 0 %}
    <div class="product-grid"> 
      {% for product in collection.products limit: s.products_to_show %}
        <div class="product-card">
          <a href="{{ product.url }}">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}">                                      
            {% endif %}
            <h3>{{ product.title }}</h3>
            <p>{{ product.price | money }}</p>
          </a>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p style="color: #718096;">Please select a collection in the theme editor sidebar to show products.</p>
  {% endif %}
</section>

{% schema %}
{
  "name": "Custom Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Custom Featured Products"
    }
  ]
}
{% endschema %}
