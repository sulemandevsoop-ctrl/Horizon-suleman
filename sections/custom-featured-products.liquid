<section class="featured-product-section">
  
  {% assign product = section.settings.product %}
  
  <div class="product-card">
    {% if product != blank %}
      <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}">
      <h3>{{ product.title }}</h3>
      <p>{{ product.price | money }}</p>
      <div>{{ product.description }}</div>
    {% else %}
      <p>Please select a product in the theme editor sidebar.</p>
    {% endif %}
  </div>

</section>

<style>
  .featured-product-section {
    padding: 20px;
    font-family: Arial, sans-serif;
  }
  .product-card {
    width: 300px;
    margin: 0 auto;
    border: 1px solid #ccc;
    padding: 15px;
    text-align: center;
  }
  .product-card img {
    width: 100%;
    height: auto;
  }
</style>

{% schema %}
{
  "name": "Featured Product Easy",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Select Product"
    }
  ],
  "presets": [
    {
      "name": "Featured Product Easy"
    }
  ]
}
{% endschema %}