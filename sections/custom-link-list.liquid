<section class="custom-menu-section">
  
  <h3>{{ section.settings.heading }}</h3>

  <ul class="custom-menu-ul">
    {% for link in section.settings.menu.links %}
      <li>
        <a href="{{ link.url }}">{{ link.title }}</a>
      </li>
    {% endfor %}
  </ul>

</section>

<style>
  .custom-menu-section {
    padding: 20px;
  }
  .custom-menu-ul {
    list-style-type: none;
    padding: 0;
  }
  .custom-menu-ul li {
    display: inline-block;
    margin-right: 15px;
    margin-bottom: 10px;
  }
  .custom-menu-ul li a {
    text-decoration: none;
    color: blue;
    font-size: 18px;
  }
  .custom-menu-ul li a:hover {
    color: red;
  }
</style>

{% schema %}
{
  "name": "Custom Link List",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Select Menu / Link List"
    }
  ],
  "presets": [
    {
      "name": "Custom Link List"
    }
  ]
}
{% endschema %}